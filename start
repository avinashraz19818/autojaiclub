#!/bin/bash

# Bot Startup Script with Virtual Environment Support
# This script handles:
# - Virtual environment creation/activation
# - Dependency installation
# - Clean process termination
# - Bot startup with proper PID management
# - Logging and error handling

set -euo pipefail  # Strict error handling

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Configuration
BOT_SCRIPT="autojaiclub.py"
VENV_DIR=".venv"
PID_FILE="bot.pid"
LOG_FILE="bot.log"
REQUIREMENTS_FILE="requirements.txt"
MAX_WAIT=10  # Max seconds to wait for bot to start

# Logging function
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Header
echo ""
echo "=========================================="
echo "    🤖 WIN GO BOT STARTUP SCRIPT 🤖"
echo "=========================================="
echo ""

# Check if bot script exists
if [ ! -f "$BOT_SCRIPT" ]; then
    log_error "Bot script '$BOT_SCRIPT' not found!"
    exit 1
fi

# ─────────────────────────────────────────────────────────────────────────────
# 1. Check Python installation
# ─────────────────────────────────────────────────────────────────────────────
log_info "Checking Python installation..."

if ! command -v python3 &> /dev/null; then
    log_error "Python 3 is not installed!"
    exit 1
fi

PYTHON_VERSION=$(python3 --version 2>&1)
log_success "Python version: $PYTHON_VERSION"

# ─────────────────────────────────────────────────────────────────────────────
# 2. Virtual Environment Setup
# ─────────────────────────────────────────────────────────────────────────────
log_info "Setting up virtual environment..."

# Check if venv exists and is valid
if [ -d "$VENV_DIR" ]; then
    # Check if venv has a valid Python interpreter
    if [ ! -x "$VENV_DIR/bin/python3" ] || ! "$VENV_DIR/bin/python3" --version >/dev/null 2>&1; then
        log_warning "Broken virtual environment found! Removing..."
        rm -rf "$VENV_DIR"
    else
        log_info "Virtual environment already exists."
    fi
fi

# Create virtual environment if needed
if [ ! -d "$VENV_DIR" ]; then
    log_info "Creating new virtual environment..."
    python3 -m venv "$VENV_DIR"
    if [ ! -d "$VENV_DIR" ]; then
        log_error "Failed to create virtual environment!"
        exit 1
    fi
    log_success "Virtual environment created successfully."
fi

# Activate virtual environment
log_info "Activating virtual environment..."
source "$VENV_DIR/bin/activate"

if [ -z "$VIRTUAL_ENV" ]; then
    log_error "Failed to activate virtual environment!"
    exit 1
fi

log_success "Virtual environment activated: $VIRTUAL_ENV"
log_info "Python path: $(which python3)"

# ─────────────────────────────────────────────────────────────────────────────
# 3. Install/Update Dependencies
# ─────────────────────────────────────────────────────────────────────────────
log_info "Checking dependencies..."

if [ -f "$REQUIREMENTS_FILE" ]; then
    # Upgrade pip
    log_info "Upgrading pip..."
    pip install --upgrade pip -q 2>/dev/null || true
    
    # Install requirements
    log_info "Installing requirements from $REQUIREMENTS_FILE..."
    pip install -r "$REQUIREMENTS_FILE" -q 2>/dev/null || {
        log_warning "Some packages failed to install quietly, retrying with output..."
        pip install -r "$REQUIREMENTS_FILE"
    }
    
    log_success "Dependencies installed successfully."
else
    log_warning "Requirements file '$REQUIREMENTS_FILE' not found!"
    
    # Install common dependencies if requirements.txt doesn't exist
    log_info "Installing common dependencies..."
    pip install python-telegram-bot==20.7 aiohttp pymongo numpy scikit-learn pyrogram -q 2>/dev/null || {
        log_error "Failed to install dependencies!"
        exit 1
    }
fi

# ─────────────────────────────────────────────────────────────────────────────
# 4. Clean up existing bot instances
# ─────────────────────────────────────────────────────────────────────────────
log_info "Cleaning up existing bot instances..."

# Kill by PID file
if [ -f "$PID_FILE" ]; then
    OLD_PID=$(cat "$PID_FILE" 2>/dev/null || echo "")
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        log_info "Killing process with PID $OLD_PID..."
        kill -TERM "$OLD_PID" 2>/dev/null || true
        sleep 2
        if kill -0 "$OLD_PID" 2>/dev/null; then
            log_warning "Process $OLD_PID didn't stop, forcing kill..."
            kill -9 "$OLD_PID" 2>/dev/null || true
        fi
        log_success "Killed PID $OLD_PID"
    fi
    rm -f "$PID_FILE"
fi

# Kill all bot processes by script name (multiple instances)
log_info "Searching for running bot instances..."
BOT_PIDS=$(pgrep -f "python.*$BOT_SCRIPT" 2>/dev/null || true)
if [ -n "$BOT_PIDS" ]; then
    log_info "Found running bot instances: $BOT_PIDS"
    for pid in $BOT_PIDS; do
        log_info "Stopping bot process $pid..."
        kill -TERM "$pid" 2>/dev/null || true
    done
    sleep 3
    # Check for any remaining processes
    REMAINING=$(pgrep -f "python.*$BOT_SCRIPT" 2>/dev/null || true)
    if [ -n "$REMAINING" ]; then
        log_warning "Force killing remaining processes: $REMAINING"
        for pid in $REMAINING; do
            kill -9 "$pid" 2>/dev/null || true
        done
    fi
    log_success "All bot instances stopped."
else
    log_info "No running bot instances found."
fi

# Kill any Telegram polling sessions (optional)
# pkill -f "telegram.*polling" 2>/dev/null || true

# Wait for resources to be freed
sleep 2

# ─────────────────────────────────────────────────────────────────────────────
# 5. Start bot instance
# ─────────────────────────────────────────────────────────────────────────────
log_info "Starting bot instance..."

# Clear old log file (optional - backup old logs)
if [ -f "$LOG_FILE" ]; then
    # Keep last 10 log files
    if [ -f "${LOG_FILE}.10" ]; then
        rm -f "${LOG_FILE}.10"
    fi
    for i in {9..1}; do
        if [ -f "${LOG_FILE}.$i" ]; then
            mv "${LOG_FILE}.$i" "${LOG_FILE}.$((i+1))"
        fi
    done
    mv "$LOG_FILE" "${LOG_FILE}.1"
fi

# Start bot with nohup
nohup python3 "$BOT_SCRIPT" >> "$LOG_FILE" 2>&1 &
BOT_PID=$!

# Save PID
echo "$BOT_PID" > "$PID_FILE"
log_success "Bot started with PID: $BOT_PID"

# ─────────────────────────────────────────────────────────────────────────────
# 6. Verify bot is running
# ─────────────────────────────────────────────────────────────────────────────
log_info "Verifying bot is running..."

# Wait for bot to start
VERIFY_COUNT=0
while [ $VERIFY_COUNT -lt $MAX_WAIT ]; do
    if kill -0 "$BOT_PID" 2>/dev/null; then
        log_success "✅ Bot is running successfully!"
        echo ""
        echo "=========================================="
        echo "   Bot Status: RUNNING"
        echo "   PID: $BOT_PID"
        echo "   Log file: $LOG_FILE"
        echo "   To view logs: tail -f $LOG_FILE"
        echo "   To stop bot: ./stop_bot.sh"
        echo "=========================================="
        echo ""
        
        # Show last few log lines if available
        if [ -f "$LOG_FILE" ] && [ -s "$LOG_FILE" ]; then
            echo "Last few log entries:"
            echo "----------------------------------------"
            tail -5 "$LOG_FILE"
            echo "----------------------------------------"
        fi
        exit 0
    fi
    sleep 1
    VERIFY_COUNT=$((VERIFY_COUNT + 1))
done

# If we get here, bot didn't start
log_error "❌ Bot failed to start! Check log file for details:"
echo ""
if [ -f "$LOG_FILE" ]; then
    echo "--- BEGIN LOG ---"
    tail -50 "$LOG_FILE"
    echo "--- END LOG ---"
else
    echo "No log file found."
fi

# Clean up PID file if bot didn't start
rm -f "$PID_FILE"
exit 1